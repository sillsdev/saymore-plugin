{
  // See D:/lameta/plugins/docs/plugin-authoring.md.
  id: "org.sil.saymore-audio",
  name: "SayMore Audio Annotation",
  version: "0.0.0", // display only; semver
  apiVersion: 1, // plugin API major version
  description: "SayMore-compatible audio annotation. Manual Segmenter now; Auto Segmenter and the Transcription grid to follow.",
  author: "SIL Global",

  permissions: ["companionFiles"],

  // Tab-provider model (host ASKS the plugin): on every selection the host loads this entry
  // as a hidden provider and calls getTabs; the SPA (src/plugin/tabProvider.ts) answers LIVE
  // and UNCACHED from the current companion state:
  //   - Audio with no <media>.annotations.eaf → one "SayMore: Start Annotating" tab (button)
  //   - Audio that already has an .eaf         → NO tab (edit via the .eaf's own tab)
  //   - a selected .eaf                        → one "Segments" tab (the manual segmenter)
  // When a returned tab is opened, the same entry loads as a content tab and self-renders.
  // `handles` is a coarse capability hint so the host only queries us for relevant files.
  tabProvider: {
    entry: "index.html",
    handles: { lametaTypes: ["Audio"], extensions: ["eaf"] },
  },
}
